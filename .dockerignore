# Git metadata
.git
.gitignore

# Environment / secrets — never bake these into the image
.env
.env.*

# Dev artifacts
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Private keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# OS / editor clutter
.DS_Store
*.swp

# Docs / assets not needed at runtime
README.md
logo.png
LICENSE
